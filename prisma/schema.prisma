// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model SimulationRun {
  id          String   @id @default(cuid())
  name        String
  status      String   @default("draft")
  assumptions Json?
  results     Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String
  createdAt    DateTime  @default(now())
  sessions     Session[]
  strategies   Strategy[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Strategy {
  id         String   @id @default(cuid())
  userId     String
  allocation Json
  metrics    Json
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ShockEvent {
  id           String   @id @default(cuid())
  title        String
  description  String
  marketImpact Json
  modifiers    Json
  active       Boolean  @default(false)
  weekStart    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([active])
  @@index([weekStart])
}
